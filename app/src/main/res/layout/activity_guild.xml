<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#121212"
    android:padding="16dp">

    <TextView
        android:id="@+id/tv_guild_title"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Guild"
        android:textAlignment="center"
        android:textColor="#FFC107"
        android:textSize="24sp"
        android:textStyle="bold"
        android:layout_marginBottom="16dp" />

    <!-- Join/Create UI -->
    <LinearLayout
        android:id="@+id/ll_no_guild"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:visibility="visible">

        <EditText
            android:id="@+id/et_guild_name"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Guild Name / ID"
            android:textColor="#FFFFFF"
            android:textColorHint="#AAAAAA"
            android:backgroundTint="#00BCD4" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="8dp">

            <Button
                android:id="@+id/btn_create_guild"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="wrap_content"
                android:text="Create Guild"
                android:backgroundTint="#4CAF50" />

            <View
                android:layout_width="8dp"
                android:layout_height="match_parent" />

            <Button
                android:id="@+id/btn_join_guild"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="wrap_content"
                android:text="Join Guild"
                android:backgroundTint="#2196F3" />
        </LinearLayout>
    </LinearLayout>

    <!-- Guild Active UI -->
    <LinearLayout
        android:id="@+id/ll_has_guild"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:visibility="gone">

        <TextView
            android:id="@+id/tv_active_guild_name"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Guild Name"
            android:textColor="#FFFFFF"
            android:textSize="20sp"
            android:textStyle="bold" />
            
        <TextView
            android:id="@+id/tv_guild_id"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="ID: "
            android:textColor="#AAAAAA"
            android:textSize="14sp"
            android:layout_marginBottom="16dp" />

        <!-- Raid Boss -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Raid Boss"
            android:textColor="#F44336"
            android:textSize="18sp"
            android:textStyle="bold" />

        <ProgressBar
            android:id="@+id/pb_boss_health"
            style="?android:attr/progressBarStyleHorizontal"
            android:layout_width="match_parent"
            android:layout_height="24dp"
            android:max="10000"
            android:progress="10000"
            android:progressTint="#F44336"
            android:layout_marginTop="8dp" />

        <TextView
            android:id="@+id/tv_boss_health_text"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="10000 / 10000 HP"
            android:textColor="#FFFFFF"
            android:textAlignment="center"
            android:layout_marginBottom="16dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Leaderboard"
            android:textColor="#00BCD4"
            android:textSize="18sp"
            android:textStyle="bold"
            android:layout_marginBottom="8dp" />

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rv_leaderboard"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1" />

        <Button
            android:id="@+id/btn_leave_guild"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Leave Guild"
            android:backgroundTint="#F44336"
            android:layout_marginTop="16dp" />
    </LinearLayout>

</LinearLayout>